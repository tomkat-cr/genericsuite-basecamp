###################################
# C O M M O N   V A R I A B L E S #
###################################

# Aplicacion name
APP_NAME=fastapitemplate

# Application debug (0,1)
APP_DEBUG=0
# APP_DEBUG=1

# API version (default to "v1")
API_VERSION=v1

# Local frontend API port (used by server.js, webpack.config.js, and config-overrides.js)
FRONTEND_LOCAL_PORT=3000

# Local backend API port (used by run_app_backend.sh)
BACKEND_LOCAL_PORT=5001

# Local run http/https protocol, to have it automatically on the application local running, no user intervention.
RUN_PROTOCOL="http"
# RUN_PROTOCOL="https"

# Config JSON configuration files Git URL
GIT_SUBMODULE_URL=git://github.com/github-username/fastapitemplate_configs.git

# AWS Configuration
#
# Region for this App all AWS services
AWS_REGION=aws-region

# Docker account username (used by vps and jfrog scripts)
DOCKER_ACCOUNT=docker_account_username


#######################################
# F R O N T E N D   V A R I A B L E S #
#######################################

# Local domain name (used in the CNAME file of local DNS)
APP_LOCAL_DOMAIN_NAME=app.fastapitemplate.local
# APP_LOCAL_DOMAIN_NAME=localhost

# Backend path (used by create_ssl_certs.sh)
BACKEND_PATH=../server

# Local development environment running method
# * Vite (default):
# RUN_BUNDLER="vite"
# * Webpack:
# RUN_BUNDLER="webpack"
# * React-app-rewired (better error reporting when running dev)
# RUN_BUNDLER="react-scripts"

# Backend API URL (assigned by run_app_frontend.sh)
REACT_APP_API_URL=http://localhost:5000

# Backend API for each stage/environment
APP_API_URL_DEV=http://127.0.0.1:5000
APP_API_URL_QA=http://api-qa.fastapitemplate.com
APP_API_URL_STAGING=http://api-staging.fastapitemplate.com
APP_API_URL_PROD=https://api.fastapitemplate.com
APP_API_URL_DEMO=https://api-demo.fastapitemplate.com

# Frontend URL (assigned by change_env_be_endpoint.sh and used by aws_deploy_to_s3.sh, aws_get_ssl_cert_arn.sh, and run_app_frontend.sh)
APP_FE_URL=https://app.fastapitemplate.com

# Frontend URL for each stage/environment (used by aws_deploy_to_s3.sh to assing APP_FE_URL)
APP_FE_URL_QA=https://app-qa.fastapitemplate.com
APP_FE_URL_STAGING=https://app-staging.fastapitemplate.com
APP_FE_URL_PROD=https://app.fastapitemplate.com
APP_FE_URL_DEMO=https://app-demo.fastapitemplate.com

# App URI prefix
REACT_APP_URI_PREFIX=fastapitemplate_ui

# Use 'x-access-tokens' instead of 'Authorization: Bearer'
# REACT_APP_X_TOKEN=1

# AWS Configuration
#
# S3 bucket to deploy the frontend application
# (used by aws_deploy_to_s3.sh and change_env_be_endpoint.sh)
AWS_S3_BUCKET_NAME=aws_s3_bucket_name
AWS_S3_BUCKET_NAME_DEV=aws_s3_bucket_name_dev
AWS_S3_BUCKET_NAME_QA=aws_s3_bucket_name_qa
AWS_S3_BUCKET_NAME_STAGING=aws_s3_bucket_name_staging
AWS_S3_BUCKET_NAME_PROD=aws_s3_bucket_name_prod
AWS_S3_BUCKET_NAME_DEMO=aws_s3_bucket_name_demo

# Frontend: Config JSON files submodule configuration (used by add_github_submodules.sh)
GIT_SUBMODULE_LOCAL_PATH_FRONTEND=src/configs


#####################################
# B A C K E N D   V A R I A B L E S #
#####################################

# Aplicacion domain
APP_DOMAIN_NAME=fastapitemplate.com

# Aplicacion AI assistant name
AI_ASSISTANT_NAME="AI Assistant"

# Application default language
DEFAULT_LANG=en
# DEFAULT_LANG=es

################################

# Application secret key (to set password encryption)
APP_SECRET_KEY=xxxx

# Application super admin email
APP_SUPERADMIN_EMAIL=xxxx

#########################
#
# Database configuration
#

# For MongoDB
#
# DEV: Docker container
APP_DB_ENGINE_DEV=MONGODB
APP_DB_NAME_DEV=mongo
APP_DB_URI_DEV=mongodb://root:example@app.exampleapp.local:27017/
# APP_DB_URI_DEV=mongodb://root:example@127.0.0.1:27017/

# Use USE_LOCAL_MONGODB=1 to enable only local database on the docker compose
# E.g. to use the 'make dev' command (running frontend and backend without
# docker compose) with local database in docker compose
# USE_LOCAL_MONGODB=1

# QA: MongoDB Atlas
APP_DB_ENGINE_QA=MONGODB
APP_DB_NAME_QA=xxxx
APP_DB_URI_QA=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

# Staging: MongoDB Atlas
APP_DB_ENGINE_STAGING=MONGODB
APP_DB_NAME_STAGING=xxxx
APP_DB_URI_STAGING=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

# PROD: MongoDB Atlas
APP_DB_ENGINE_PROD=MONGODB
APP_DB_NAME_PROD=xxxx
APP_DB_URI_PROD=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

# DEMO: MongoDB Atlas
APP_DB_ENGINE_DEMO=MONGODB
APP_DB_NAME_DEMO=xxxx
APP_DB_URI_DEMO=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

# For AWS DynamoDB
#
# # DEV: docker
# APP_DB_ENGINE_DEV=DYNAMODB
# DYNAMDB_PREFIX_DEV=
# APP_DB_URI_DEV=http://127.0.0.1:8000
#
# # QA:
# APP_DB_ENGINE_QA=DYNAMODB
# DYNAMDB_PREFIX_QA=
# APP_DB_URI_QA=
#
# # PROD:
# APP_DB_ENGINE_PROD=DYNAMODB
# DYNAMDB_PREFIX_PROD=
# APP_DB_URI_PROD=
#
# # DEMO:
# APP_DB_ENGINE_DEMO=DYNAMODB
# DYNAMDB_PREFIX_DEMO=
# APP_DB_URI_DEMO=

# For PostgreSQL
#
# # DEV: docker
# APP_DB_ENGINE_DEV=POSTGRES
# APP_DB_URI_DEV=postgresql://user:pass@localhost:5432
# APP_DB_NAME_DEV=db
#
# # QA:
# APP_DB_ENGINE_QA=POSTGRES
# APP_DB_URI_QA=postgresql://user:pass@hostname:5432
# APP_DB_NAME_QA=db
#
# # PROD:
# APP_DB_ENGINE_PROD=POSTGRES
# APP_DB_URI_PROD=postgresql://user:pass@hostname:5432
# APP_DB_NAME_PROD=db
#
# # DEMO:
# APP_DB_ENGINE_DEMO=POSTGRES
# APP_DB_URI_DEMO=postgresql://user:pass@hostname:5432
# APP_DB_NAME_DEMO=db

# For Supabase
#
SUPABASE_KEY=
#
# # DEV: docker
# APP_DB_ENGINE_DEV=SUPABASE
# APP_DB_URI_DEV=https://xxxx.supabase.co
# APP_DB_NAME_DEV=db
#
# # QA:
# APP_DB_ENGINE_QA=SUPABASE
# APP_DB_URI_QA=https://xxxx.supabase.co
# APP_DB_NAME_QA=db
#
# # PROD:
# APP_DB_ENGINE_PROD=SUPABASE
# APP_DB_URI_PROD=https://xxxx.supabase.co
# APP_DB_NAME_PROD=db
#
# # DEMO:
# APP_DB_ENGINE_DEMO=SUPABASE
# APP_DB_URI_DEMO=https://xxxx.supabase.co
# APP_DB_NAME_DEMO=db

# For MySQL
#
# # DEV: docker
# APP_DB_ENGINE_DEV=MYSQL
# APP_DB_URI_DEV=mysql://user:pass@localhost:3306
# APP_DB_NAME_DEV=db
#
# # QA:
# APP_DB_ENGINE_QA=MYSQL
# APP_DB_URI_QA=mysql://user:pass@hostname:3306
# APP_DB_NAME_QA=db
#
# # PROD:
# APP_DB_ENGINE_PROD=MYSQL
# APP_DB_URI_PROD=mysql://user:pass@hostname:3306
# APP_DB_NAME_PROD=db
#
# # DEMO:
# APP_DB_ENGINE_DEMO=MYSQL
# APP_DB_URI_DEMO=mysql://user:pass@hostname:3306
# APP_DB_NAME_DEMO=db

#########################

# App CORS origin

# # DEV
APP_CORS_ORIGIN_DEV=*
# # QA
APP_CORS_ORIGIN_QA=https://app.fastapitemplate.local:3000
APP_CORS_ORIGIN_QA_CLOUD=https://app-qa.fastapitemplate.com
APP_CORS_ORIGIN_QA_LOCAL=https://app.fastapitemplate.local:3000
# # STAGING
APP_CORS_ORIGIN_STAGING=https://app-staging.fastapitemplate.com
# # PROD
APP_CORS_ORIGIN_PROD=https://app.fastapitemplate.com
# # DEMO
APP_CORS_ORIGIN_DEMO=https://app-demo.fastapitemplate.com

# OpenAI API key
OPENAI_API_KEY=openai_api_key

# Flask configuration
FLASK_APP=lib/index.py
# FLASK_APP=index.py
FLASK_SECRET_KEY=xxxx

################################

# Python package and dependency management tool (uv, pipenv, and poetry), default to "uv"
# PEM_TOOL=uv
# PEM_TOOL=poetry
# PEM_TOOL=pipenv

# Current framework options: chalice, flask, fastapi, mcp
# CURRENT_FRAMEWORK=mcp
# CURRENT_FRAMEWORK=flask
# CURRENT_FRAMEWORK=chalice
CURRENT_FRAMEWORK=fastapi

# Local development environment run configuration
# Options are: uvicorn, gunicorn, chalice, chalice_docker
# Chalice case: "chalice" to use http (running without docker) or "chalice_docker" to use https (with docker)
# http:
#RUN_METHOD="chalice"
# https:
# RUN_METHOD="chalice_docker"
# RUN_METHOD="gunicorn"
RUN_METHOD="uvicorn"
#
# Application main directory
# * FastAPI:
# APP_DIR=app
# * Flask:
# APP_DIR=flaskr
# * Chalice:
# APP_DIR=.
# * Basecamp:
APP_DIR=lib

# JSON configuration files location and git URL
GIT_SUBMODULE_LOCAL_PATH=lib/config_dbdef

# Frontend application path (to copy version file during big lambdas deployment)
FRONTEND_PATH=../ui

# Local pythoon version
PYTHON_VERSION=3.11.5

# IAAS Cloud provider
CLOUD_PROVIDER=aws

# Enable/disable Cloud Provider secrets (instead of environment variables).
# Available options: `1` to enable, `0` to disable. Defaults to: 1
# GET_SECRETS_ENABLED=0
#
# Fine grained Cloud Provider secrets management:
#
# Enable/disable Cloud Provider envvars.
# Available options: `1` to enable, `0` to disable. Defaults to: 1
# Set to "0" in local development environment so envvars like APP_CORS_ORIGIN can be
# set by the scripts and .env file and access QA resources from DEV.
GET_SECRETS_ENVVARS=0
#
# Enable/disable Cloud Provider critical secrets.
# Available options: `1` to enable, `0` to disable. Defaults to: 1
# Set to "0" in local development environment so envvars like APP_DB_URI can be
# set by the scripts and .env file and access QA resources from DEV.
GET_SECRETS_CRITICAL=0

# AWS Configuration
#
# AWS S3 bucket name for attachments
AWS_S3_CHATBOT_ATTACHMENTS_BUCKET_DEV=fastapitemplate-chatbot-attachments-dev
AWS_S3_CHATBOT_ATTACHMENTS_BUCKET_QA=fastapitemplate-chatbot-attachments-qa
AWS_S3_CHATBOT_ATTACHMENTS_BUCKET_STAGING=fastapitemplate-chatbot-attachments-staging
AWS_S3_CHATBOT_ATTACHMENTS_BUCKET_PROD=fastapitemplate-chatbot-attachments-prod
AWS_S3_CHATBOT_ATTACHMENTS_BUCKET_DEMO=fastapitemplate-chatbot-attachments-demo
#
# AWS Deployment type
# Available options: `lambda`, `fargate`, `ec2`. Defaults to: lambda
AWS_DEPLOYMENT_TYPE=lambda
#
# AWS base name for Lambda Functions, API Gateway, EC2, ELB, etc.
AWS_LAMBDA_FUNCTION_NAME=fastapitemplate-backend
#
# AWS Lambda function role:
# These variables are used only if deploy without AWS SAM (deploy_without_sam) in big_lambdas_manager.sh. SAM generates this role automatically
AWS_LAMBDA_FUNCTION_ROLE_QA=fastapitemplate-api_handler-role-qa
AWS_LAMBDA_FUNCTION_ROLE_STAGING=fastapitemplate-api_handler-role-staging
AWS_LAMBDA_FUNCTION_ROLE_PROD=fastapitemplate-api_handler-role-prod
AWS_LAMBDA_FUNCTION_ROLE_DEMO=fastapitemplate-api_handler-role-demo
#
# AWS SSL certificate ARN (used by big_lambdas_manager.sh)
# AWS_SSL_CERTIFICATE_ARN=arn:aws:acm:AWS-REGION:AWS-ACCOUNT:certificate/AWS-CERTIFICATE-UUID
#
# AWS S3 bucket name (used by set_fe_cloudfront_domain.sh to set the CloudFront domain name in the frontend for the CORS config)
AWS_S3_BUCKET_NAME_FE=fastapitemplate-frontend-website-[STAGE]

# Storage URL encryption
#
# Storage URL encryption (default to 0)
# STORAGE_URL_ENCRYPTION=1
#
# Storage seed (to set storage URL encryption -e.g. AWS S3-)
# Generate a new one with: `make generate_seed`
# STORAGE_URL_SEED=yyy
#
# Development URL masking external hostname
#   For features like AI Vision, to send the image URL masked.
#   It's recommended to set only in development environment.
#   E.g. URL_MASK_EXTERNAL_HOSTNAME=app-dev.exampleapp.com
#   Leave blank to use the same URL stored -for example- in the AI Assistant conversarions.
# URL_MASK_EXTERNAL_HOSTNAME=
#
# URL masking external protocol (http or https, defaults to RUN_PROTOCOL or https)
# URL_MASK_EXTERNAL_PROTOCOL=http

# AI technology (openai/langchain APIs)

# AI_TECHNOLOGY="openai"
AI_TECHNOLOGY="langchain"
#
# Google configuration
GOOGLE_API_KEY=google_console_api_key
GOOGLE_CSE_ID=google_console_cse_key
#
# OpenAI configuration
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
#
# Langchain/LangSmith configuration
# LANGCHAIN_API_KEY=langchain_api_key
# LANGCHAIN_PROJECT=langchain_project
#
# Hugging Face credentials and model URL
HUGGINGFACE_API_KEY=huggingface_api_key
HUGGINGFACE_ENDPOINT_URL=huggingface_endpoint_url

# SMTP Mail configuration
SMTP_SERVER=smtp_server
SMTP_PORT=smtp_port
SMTP_USER=smtp_user
SMTP_PASSWORD=smtp_password
SMTP_DEFAULT_SENDER=sender_email

# Tests configuration

# Backend debug local port
# BACKEND_DEBUG_LOCAL_PORT=5002

# Testing endpoint
TEST_APP_URL=http://app.fastapitemplate.local:5002

# Disable local DNS server startup during app run (for offline development)
# LOCAL_DNS_DISABLED=1
# Disable bridge proxy startup during app run (for offline development)
# BRIDGE_PROXY_DISABLED=1

# Container engine: used by the docker run command to run the container
# Available options: `docker`, `podman`. Defaults to: docker
# CONTAINER_ENGINE=docker
# CONTAINER_ENGINE=podman

# Open containers engine app
# Available options: `1` to enable, `0` to disable. Defaults to: 1
# OPEN_CONTAINERS_ENGINE_APP=1
OPEN_CONTAINERS_ENGINE_APP=0

# Check "genericsuite-be-scripts/scripts/link_gs_libs_for_dev.sh"
# BASE_DEVELOPMENT_PATH="/Users/username/base_path_to_genericsuite_repos"


###########################################
# M C P   S E R V E R   V A R I A B L E S #
###########################################

# Application main directory
MCP_APP_DIR=../server
MCP_APP_MAIN_FILE=lib.mcp_server
MCP_SERVER_RUN_AS_MODULE=true

# MCP configuration
#
# MCP server port (default to 8000)
# MCP_SERVER_PORT=8000
#
# MCP server host (default to 0.0.0.0)
# MCP_SERVER_HOST="0.0.0.0"
#
# MCP server transport method.
#   Default to stdio (and runs over MCP Inspector) when MCP_DEBUG_MODE=1
#   Default to http when MCP_DEBUG_MODE=0
# MCP_TRANSPORT=stdio
# MCP_TRANSPORT=http
#
# GenericSuite user name (for automatic authentication)
GS_USER_NAME=
# GenericSuite user id (for automatic authentication)
GS_USER_ID=
# GenericSuite API key (for automatic authentication)
GS_API_KEY=
