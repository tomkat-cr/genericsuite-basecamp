{
  "name": "api_server",
  "version": "1.0.0",
  "description": "fastapitemplate (FastAPI backend)",
  "author": "Carlos Ramirez",
  "license": "Private",
  "type": "module",
  "homepage": "https://github.com/github-username/fastapitemplate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/github-username/fastapitemplate.git"
  },
  "bugs": {
    "url": "https://github.com/github-username/fastapitemplate/issues"
  },
  "scripts": {
    "api:install": "make install",
    "api:update": "make update",
    "dev": "make run_qa",
    "dev:start": "npm run start:qa",
    "build": "make install_dev",
    "build:from_root": "npm run build",
    "test": "bash ../node_modules/genericsuite-be-scripts/scripts/aws/run_aws.sh test",
    "start:local": "bash ../node_modules/genericsuite-be-scripts/scripts/aws/run_aws.sh",
    "start:qa": "bash ../node_modules/genericsuite-be-scripts/scripts/aws/set_chalice_cnf.sh qa && bash ../node_modules/genericsuite-be-scripts/scripts/aws/run_aws.sh run_local qa",
    "deploy": "bash ../node_modules/genericsuite-be-scripts/scripts/aws/run_aws.sh deploy",
    "pipfile": "bash ../node_modules/genericsuite-be-scripts/scripts/aws/run_aws.sh pipfile",
    "shell": "bash ../node_modules/genericsuite-be-scripts/scripts/aws/run_aws.sh shell",
    "clean": "rm -rf __pycache__ bin pyvenv.cfg .venv node_modules",
    "coverage": "make coverage",
    "lint": "make lint",
    "check-types": "make check-types"
  },
  "dependencies": {
    "genericsuite-be-scripts": "^1.2.0"
  }
}